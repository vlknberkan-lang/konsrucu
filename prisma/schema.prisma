// KonsRücü — veri modeli (kanonik kaynak). Tasarım: docs/02-veri-modeli.md
// Çok-kiracılı (Musteri = sigortacı). Dosya = kalıcı tam kayıt (hub).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // serverless runtime (transaction pooler 6543)
  directUrl = env("DIRECT_URL") // migration/push (session pooler 5432)
}

// ─────────────────── enum'lar ───────────────────
enum Rol {
  ADMIN
  AVUKAT
  AVUKAT_YRD
  GORUNTULEYEN
}

enum Yol {
  KLASIK
  IDARI
  BELIRSIZ
}

enum DosyaDurum {
  HAVUZDA
  INCELENIYOR
  TAKIBE_HAZIR
  TAKIP_ACILDI
  TEBLIG_EDILDI
  ITIRAZ
  ARABULUCULUK
  DAVA
  KESINLESTI
  INFAZ
  TAHSIL
  KAPANDI
  IDARI_YOL
}

enum Brans {
  KASKO
  ZMMS
  OTO_DISI
}

enum BorcluRol {
  RUHSAT_SAHIBI
  SURUCU
  ISVEREN
  KAT_MALIKI
  YONETIM
  DIGER
}

enum TeyitDurum {
  TEYIT_EDILDI
  TEYIT_GEREK
  SUPHE
}

enum BelgeKategori {
  POLICE
  DEKONT
  LEHE
  EKSPERTIZ
  TUTANAK
  SBM
  EHLIYET
  RUHSAT
  ALKOL
  HASAR_FOTO
  DIGER
}

enum CiktiTip {
  TAKIP_BLOGU
  DILEKCE
  BILGILER_JSON
}

// aşama omurgası — 5 sekme: İcra Öncesi (asama yok) · İcra · Arabuluculuk · Dava · İnfaz (ilamlı, aynı esas)
enum AsamaTur {
  ICRA_TAKIBI
  ARABULUCULUK
  DAVA
  INFAZ
}

enum AsamaDurum {
  DEVAM
  SONUCLANDI
  IPTAL
}

enum EtkinlikTur {
  ARABULUCULUK_TOPLANTISI
  DURUSMA
  SURE
  HATIRLATMA
  GORUSME
}

enum EtkinlikDurum {
  PLANLANDI
  YAPILDI
  YAPILMADI // planlandı ama gerçekleşmedi (henüz yeni tarih yok) — takip görevi tetikler
  ERTELENDI // yapılmadı ama yeni tarih kararlaştırıldı
  IPTAL
}

// takip görevi (etkinlikten doğan iş) durum makinesi — OnemliOlay ile aynı dil
enum TakipGorevDurum {
  ACIK
  ISLEMDE
  TAMAMLANDI
  IPTAL
}

// taksitlendirme (sulh/anlaşma sonrası ödeme planı) — plan + tek tek taksit
enum TaksitPlanDurum {
  AKTIF
  TAMAMLANDI
  TEMERRUT // bir taksit kaçtı, kalan muaccel oldu (avukat kararıyla)
  IPTAL
}

enum TaksitDurum {
  BEKLIYOR
  ODENDI
  KISMI
  GECIKTI
}

// masraf/harç takibi (müvekkile faturalanacak icra masrafları) — makbuz PDF'inden çıkarılır + manuel
enum MasrafDurum {
  YENI
  ONAYLI
  FATURALANDI
  TAHSIL
  ARSIV
}

enum MasrafTaraf {
  BIZ // bizim/müvekkil-büro ödemesi → faturalanır
  KARSI // karşı taraf masrafı → HARİÇ
  BELIRSIZ // belirlenemedi → kullanıcı karar verir (otomatik dahil edilmez)
}

// önemli olay (görev/alarm kuyruğu) — şimdilik tek tip: borca itiraz → arabuluculuk. Genişletilebilir.
enum OnemliOlayTip {
  BORCA_ITIRAZ
}

// mentor geri bildirim — AI'ın hangi çıktısı düzeltildi (Önerilen Adımlar / Riskler ve Öneriler)
enum MentorKaynak {
  ADIM // "Önerilen Adımlar · mentor" (sonrakiAdimlar)
  TEYIT // "Riskler ve Öneriler" (teyit notları)
}

// kural türü — bu tarz öneriyi bir daha verme (KALDIR) | öneri şöyle olmalı (DUZELT)
enum MentorKuralTur {
  KALDIR
  DUZELT
}

// Açık → İşlemde (üstlenildi/kilitli) → Tamamlandı (resmî teyit) | İptal (mükerrer/yanlış)
enum OnemliOlayDurum {
  ACIK
  ISLEMDE
  TAMAMLANDI
  IPTAL
}

// ─────────────────── tenant / kullanıcı ───────────────────
model Musteri {
  id           String             @id @default(uuid())
  ad           String             @unique // "Ray Sigorta A.Ş."
  aktif        Boolean            @default(true)
  // plan + AI kredi duvarı (self-serve): FREE=25 tek-seferlik kredi + 20 aktif dosya;
  // KURUMSAL=sınırsız (mevcut Ray/Zurich kiracıları migration'da KURUMSAL yapıldı).
  plan         String             @default("FREE") // FREE | BASLANGIC | BURO | KURUMSAL
  aiKredi      Int                @default(25) // kalan kredi; KURUMSAL'da kontrol edilmez
  createdAt    DateTime           @default(now())
  ayarlar      Ayarlar?
  dosyalar     RucuDosyasi[]
  projeler     Proje[]
  kullanicilar MusteriKullanici[]
  mentorKurallar MentorKural[]
  aiKullanimlar AiKullanim[]
}

// AI kullanım defteri — HER Anthropic çağrısı buraya düşer (maliyet görünürlüğü + faturalama temeli).
// Kredi düşümü Musteri.aiKredi'de atomik yapılır; bu tablo salt kayıttır.
model AiKullanim {
  id          String   @id @default(uuid())
  musteriId   String?
  musteri     Musteri? @relation(fields: [musteriId], references: [id], onDelete: SetNull)
  dosyaId     String? // FK değil — dosya silinse de maliyet kaydı kalsın
  yuzey       String // cikarim | dilekce | emsal | soru | yol | makbuz | foto
  model       String
  girisToken  Int
  cikisToken  Int
  maliyetUsd  Decimal  @db.Decimal(10, 6)
  krediBedeli Int      @default(0) // bu çağrıda düşülen kredi (işlemin ilk çağrısında)
  hata        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([musteriId, createdAt])
  @@index([createdAt])
}

model Kullanici {
  id             String             @id // = Supabase auth.users.id (uuid)
  ad             String
  eposta         String             @unique
  rol            Rol                @default(AVUKAT_YRD)
  // Silme yetkisi KİŞİ bazlı: Sude ile Ervanur aynı rolde (AVUKAT_YRD) olduğundan rol tek başına
  // ayıramaz. silebilir() (lib/konsrucu/db) rol + bu bayrağı birlikte kontrol eder.
  silmeYetkisi   Boolean            @default(true)
  aktif          Boolean            @default(true)
  createdAt      DateTime           @default(now())
  musteriler     MusteriKullanici[]
  atananDosyalar RucuDosyasi[]      @relation("AtananKullanici")
  onemliOlaylar  OnemliOlay[]       @relation("OnemliOlaySorumlu")
  takipGorevleri TakipGorevi[]      @relation("TakipGorevSorumlu")
  notlar         Not[]
  aktiviteler    Aktivite[]
  mentorKurallar MentorKural[]      @relation("MentorKuralYazan")
}

model MusteriKullanici {
  musteriId   String
  kullaniciId String
  musteri     Musteri   @relation(fields: [musteriId], references: [id], onDelete: Cascade)
  kullanici   Kullanici @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)

  @@id([musteriId, kullaniciId])
}

// ─────────────────── şirket bilgileri (her müşteriye ayrı) ───────────────────
model Ayarlar {
  id                 String   @id @default(uuid())
  musteriId          String   @unique
  musteri            Musteri  @relation(fields: [musteriId], references: [id], onDelete: Cascade)
  alacakliUnvan      String?
  mersis             String?
  vekilAd            String?
  vekilAdres         String?
  iban               String?
  kep                String?
  eposta             String?
  aciklamaFooter     String? // ör. "K/Partners: ..."
  faizJson           Json? // dönemsel kanuni faiz oranları
  vekilBaro          String?
  faizTuru           String?  @default("Yasal faiz")
  // Dava dilekçesi sabitleri (Ray + vekil künyesi)
  davaciVkn          String? // ör. 7340039798
  davaciAdres        String? // Ray açık adres
  vekilUets          String? // vekil UETS no
  icraInkarOrani     String?  @default("20")
  // vekaletname — TÜM dosyalarda ortak tek belge (değişmez); Storage 'evrak' bucket yolu
  vekaletnamePath    String?
  vekaletnameAd      String?
  // UYAP eklenti senkron anahtarı (Bearer) — eklentiye bir kez yapıştırılır, tenant'a bağlar
  senkronToken       String?  @unique
  // masraf modülü — öğrenilen cins eşleştirme sözlüğü (ham açıklama → 63 kalem) + modül ayarları
  masrafEslestirJson Json? // { "basvurma harci": "Başvuru Harcı", ... } (normalize edilmiş anahtar)
  masrafJson         Json? // { eposta?: string[], gonderimSaatiUtc?: number, varsayilanSorumlu?: string }
  // önemli olay (borca itiraz tespiti) — tetik desen override'ı + ileride süre kuralı; kod varsayılanı yeterli
  onemliOlayAyarJson Json? // { tetikDesenler?: string[] }
  updatedAt          DateTime @updatedAt
}

// ─────────────────── proje (müşteri altı; alacaklı/faiz override'ı) ───────────────────
model Proje {
  id            String        @id @default(cuid())
  musteriId     String
  ad            String // "Ray Sigorta"
  alacakliUnvan String? // "Ray Sigorta A.Ş."
  mersis        String?
  vergiNo       String?
  iban          String?
  kep           String?
  faizTuru      String?       @default("Yasal faiz")
  faizJson      Json?
  aktif         Boolean       @default(true)
  createdAt     DateTime      @default(now())
  musteri       Musteri       @relation(fields: [musteriId], references: [id])
  dosyalar      RucuDosyasi[]

  @@index([musteriId])
}

// ─────────────────── rücu dosyası (kalıcı tam kayıt = hub) ───────────────────
model RucuDosyasi {
  id        String  @id @default(uuid())
  musteriId String
  musteri   Musteri @relation(fields: [musteriId], references: [id])

  // proje (opsiyonel — müşteri altı gruplama)
  projeId String?
  proje   Proje?  @relation(fields: [projeId], references: [id])

  // kimlik
  hukukDosyaNo     String?
  hasarDosyaNo     String?
  hasarTarihi      DateTime?
  sigortaliUnvan   String?
  sigortaliTelefon String?
  il               String?
  muhatapOzet      String?

  // rücu
  brans      Brans?
  rucuSebebi String?
  rucuOrani  String?
  rucuTutari Decimal? @db.Decimal(14, 2)
  asilAlacak Decimal? @db.Decimal(14, 2)

  // faiz (hesap snapshot). tarihler null = OTOMATİK: başlangıç = son (ekspertiz hariç) dekont,
  // bitiş = bugün (hesap günü). faizTutari null = otomatik hesaplanan; doluysa elle override.
  faizBaslangic DateTime?
  faizBitis     DateTime?
  faizTutari    Decimal?  @db.Decimal(14, 2)
  faizHesapJson Json? // kaydedilmiş dönemsel kırılım (yasal kayıt)

  // taraflar / kaza
  sigortaliPlaka String?
  karsiPlaka     String?
  kazaYeri       String? // = yetkili icra yeri (HMK m.16)
  kazaTarihi     DateTime?
  istikamet      String?
  olusSekli      String?   @db.Text
  kusurDurumu    String?

  // triyaj + durum
  yol      Yol?
  yolGuven Float?
  yolNeden String?    @db.Text
  durum    DosyaDurum @default(HAVUZDA)

  // icra
  yetkiliIcra String?
  icraDairesi String?
  icraDosyaNo String?
  takipTarihi DateTime?
  zamanasimi  DateTime?

  // UYAP senkron (eklenti okur-yazar) — açık/kapalı durumu + son tarama anı + finansal snapshot
  uyapDurum     String?
  uyapSenkronAt DateTime?
  uyapHesapJson Json? // UYAP'tan: asıl alacak / işlemiş faiz / tahsilat / bakiye (bilgi amaçlı)
  // Eklenti v1 eşleşme raporu — kimlik (İCRA DAİRESİ + ESAS NO) çiftiyle sorgu sonucu.
  // OK | DAIRE_EKSIK | DAIRE_COZULEMEDI | BULUNAMADI | BASKA_DAIRE | COKLU_BELIRSIZ | TARAF_UYUSMAZ | HATA
  // TARAF_UYUSMAZ = alacaklı bizim şirket değil (büronun ALEYHE dosyası olabilir) → yazım yapılmaz.
  // OK dışındakiler "senkron dışı" radarına düşer; not alanı teşhisi taşır (örn. hangi dairede bulunduğu).
  uyapEslesme    String?
  uyapEslesmeNot String?

  // çıkarım izi (her alan: value + confidence + sourceRef)
  cikarimJson  Json?
  kaynakKlasor String?

  // atama
  atananKullaniciId String?
  atanan            Kullanici? @relation("AtananKullanici", fields: [atananKullaniciId], references: [id])

  // HUGO / avukat atama-akış (komut: prisma-alan — tümü opsiyonel/default, mevcut satırları bozmaz)
  kadroluAvukat    String?
  sozlesmeliAvukat String?
  islemYapanYrd    String?
  gonderenBirim    String?
  atanmaTarihi     DateTime?
  bitisTarihi      DateTime?
  hugoDurum        String?
  davaMiktari      Decimal?  @db.Decimal(14, 2)
  hugodanCekildi   Boolean   @default(false)
  kaynakJson       Json?

  // meta
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ilişkiler
  borclular      Borclu[]
  odemeler       Odeme[]
  belgeler       Belge[]
  ciktilar       UretilenCikti[]
  olaylar        TakipOlayi[]
  asamalar       Asama[]
  etkinlikler    Etkinlik[]
  taksitPlanlari TaksitPlani[]
  masraflar      Masraf[]
  onemliOlaylar  OnemliOlay[]
  takipGorevleri TakipGorevi[]
  emsaller       EmsalKarar[]
  notlar         Not[]
  aktiviteler    Aktivite[]

  // Import dedup'unun DB savunma hattı: çift tık / eşzamanlı import mükerrer dosya yaratamaz
  // (uygulama katmanındaki ön-kontrole ek). Postgres'te NULL hukukDosyaNo'lar kısıta takılmaz.
  @@unique([musteriId, hukukDosyaNo])
  @@index([musteriId])
  @@index([projeId])
  @@index([durum])
  @@index([yol])
  @@index([musteriId, zamanasimi]) // zamanaşımı radarı (cron + filtre) her gün bu aralığı tarar
  @@index([icraDosyaNo]) // UYAP senkron/evrak eşleşmesi (eski eklenti sürümleri icraDosyaNo gönderir)
  @@index([uyapSenkronAt]) // hedefler route'unun artımlı sıralaması + sağlık bekçisi
  @@index([atananKullaniciId])
  @@index([musteriId, uyapEslesme]) // "UYAP'ta bulunamayan/belirsiz" radar sayımları
}

model Borclu {
  id          String      @id @default(uuid())
  dosyaId     String
  dosya       RucuDosyasi @relation(fields: [dosyaId], references: [id], onDelete: Cascade)
  adUnvan     String
  tcVkn       String?
  telefon     String?
  adres       String?     @db.Text
  rol         BorcluRol   @default(DIGER)
  kaynak      String? // Lehe / ekspertiz / tutanak / tescil
  teyitDurumu TeyitDurum  @default(TEYIT_GEREK)
  not         String?     @db.Text

  @@index([dosyaId])
}

model Odeme {
  id         String      @id @default(uuid())
  dosyaId    String
  dosya      RucuDosyasi @relation(fields: [dosyaId], references: [id], onDelete: Cascade)
  tarih      DateTime?
  tutar      Decimal?    @db.Decimal(14, 2)
  aciklama   String?
  anaOdemeMi Boolean     @default(false) // ana ödeme = faiz başlangıcı
  haricMi    Boolean     @default(false) // anaparaya/faize dahil DEĞİL (ör. ekspertiz ücreti)

  @@index([dosyaId])
}

// masraf/harç kaydı — müvekkile (Ray) faturalanacak icra masrafı. Makbuz PDF'inden çıkarılır + manuel girilebilir.
// Faiz/alacak hesabına KARIŞMAZ (Odeme'den ayrı) — saf masraf-faturalama izi.
model Masraf {
  id      String      @id @default(uuid())
  dosyaId String
  dosya   RucuDosyasi @relation(fields: [dosyaId], references: [id], onDelete: Cascade)
  asamaId String? // hangi aşamanın masrafı (icra/dava…) — bilgi amaçlı
  asama   Asama?      @relation(fields: [asamaId], references: [id], onDelete: SetNull)

  // makbuz kimliği (Excel: B=DEKONT NO; "Sayı"/"No" mükerrer masraf fişi alanları)
  dekontNo   String?
  makbuzSayi String?
  makbuzNo   String?

  // tutar + tarih (sıralama esası = tarih, içe-aktarım tarihi DEĞİL → B4)
  tutar Decimal   @db.Decimal(14, 2)
  tarih DateTime?

  // cins (Sayfa2'deki 63 sabit kalem) — ham açıklama + eşleşmiş kalem + güven (B2)
  cinsHam   String?
  cins      String? // 63 kalemden biri (MASRAF_CINSLERI). null = "Eşleştirilmedi"
  cinsGuven Float?

  // kendi taraf filtresi (B1) + Excel K=SORUMLU sütunu
  taraf   MasrafTaraf @default(BELIRSIZ)
  sorumlu String?

  // makbuz görseli (Belge — Supabase 'evrak' bucket). doluysa "Belgeli"
  belgeId String?
  belge   Belge?  @relation(fields: [belgeId], references: [id], onDelete: SetNull)

  // durum akışı (Yeni→Onaylı→Faturalandı→Tahsil / Arşiv) + faturalama izi
  durum        MasrafDurum @default(YENI)
  faturaDonem  String? // faturalandığı dönem (ör. "2026-W26")
  faturaTarihi DateTime?

  // köken + mükerrerlik (B3) + çıkarım güveni
  kaynak    String  @default("MANUEL") // MANUEL / UYAP_PDF / TOPLU
  kaynakRef String? // içerik-temelli dedup anahtarı (dekontNo|cinsHam|tutar|tarih) — aynı makbuz iki kez girmez
  guven     Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dosyaId, kaynakRef])
  @@index([dosyaId])
  @@index([durum])
  @@index([tarih])
  @@index([taraf])
}

model Belge {
  id            String        @id @default(uuid())
  dosyaId       String
  dosya         RucuDosyasi   @relation(fields: [dosyaId], references: [id], onDelete: Cascade)
  kategori      BelgeKategori @default(DIGER)
  dosyaAdi      String
  storagePath   String // Supabase Storage yolu
  extractedText String?       @db.Text
  exifTarih     DateTime?
  kamera        String?
  genislik      Int?
  yukseklik     Int?
  confidence    Float?
  kaynakRef     String? // dış kaynak referansı (ör. UYAP evrakId) — UYAP her senkronda YENİ şifreli id verir → dedup'ta GÜVENİLMEZ, yalnız bilgi
  icerikHash    String? // içerik MD5 (hex) — UYAP evrak dedup'unun GERÇEK anahtarı (değişen evrakId yerine). Supabase Storage eTag ile aynı.
  belgeTarihi   DateTime? // belgenin GERÇEK tarihi (UYAP ad sonundan: "... 2026-06-12.pdf") — indirme/createdAt değil; sıralama bunu kullanır
  createdAt     DateTime      @default(now())
  ciktiBaglari  CiktiKaynak[]
  masraflar     Masraf[] // bu belge bir makbuz ise: ondan çıkan masraf kalemleri

  @@index([dosyaId])
  @@index([kategori])
  @@index([dosyaId, kaynakRef])
  @@index([dosyaId, icerikHash])
}

model UretilenCikti {
  id          String        @id @default(uuid())
  dosyaId     String
  dosya       RucuDosyasi   @relation(fields: [dosyaId], references: [id], onDelete: Cascade)
  tip         CiktiTip
  storagePath String?
  icerik      String?       @db.Text // takip-aç bloğu metni
  durum       String? // TASLAK / IMZAYA_GIDEN / GONDERILDI
  kaynaklar   CiktiKaynak[] // çift yönlü bağ: hangi belgelerden üretildi
  createdAt   DateTime      @default(now())

  @@index([dosyaId])
}

// Talep-anında çekilen Yargıtay emsal kararı — dosyaya özel, dilekçeye dayanak + cache (korpus organik büyür).
// Kaynak: karararama.yargitay.gov.tr (lib/konsrucu/emsal-ara.ts). 11M toplamak YOK, dosya gelince canlı ara.
model EmsalKarar {
  id          String      @id @default(uuid())
  dosyaId     String
  dosya       RucuDosyasi @relation(fields: [dosyaId], references: [id], onDelete: Cascade)
  yargitayId  String // karararama getDokuman id — yeniden-arama dedup anahtarı
  daire       String
  esasNo      String
  kararNo     String
  kararTarihi String // kaynak formatı "16.09.2019"
  alaka       String   @db.Text // AI: bu karar dosyaya neden emsal (madde atıflı kısa gerekçe)
  metin       String   @db.Text // tam karar metni (cache)
  aramaKelime String? // hangi arama ifadesinden geldi
  secili      Boolean  @default(true) // dilekçeye "Yargıtay dayanağı" olarak eklensin mi
  createdAt   DateTime @default(now())

  @@unique([dosyaId, yargitayId])
  @@index([dosyaId])
}

// üretilen çıktı <-> kaynak belge (ham evrak ↔ dilekçe çift yönlü bağ)
model CiktiKaynak {
  ciktiId String
  belgeId String
  cikti   UretilenCikti @relation(fields: [ciktiId], references: [id], onDelete: Cascade)
  belge   Belge         @relation(fields: [belgeId], references: [id], onDelete: Cascade)

  @@id([ciktiId, belgeId])
}

// izleme fazı (UYAP durum/tahsilat/tebliğ/itiraz)
model TakipOlayi {
  id        String      @id @default(uuid())
  dosyaId   String
  dosya     RucuDosyasi @relation(fields: [dosyaId], references: [id], onDelete: Cascade)
  tip       String // DURUM / TAHSILAT / TEBLIG / ITIRAZ / HESAP
  aciklama  String?     @db.Text
  tutar     Decimal?    @db.Decimal(14, 2)
  tarih     DateTime?
  hamJson   Json?
  createdAt DateTime    @default(now())

  @@index([dosyaId])
  @@index([dosyaId, tip, tarih]) // UYAP senkron dedup'u her olay için (dosya+tip+tarih) arar — olay hacmi sürekli büyür
}

// sistem olay günlüğü — hafif hata izleme (Sentry'siz): cron/mail/senkron hataları buraya düşer,
// Şirket Bilgileri'ndeki "Sistem Olayları" kartından okunur. Üretimde bir şey sessizce ölmesin.
model SistemOlay {
  id        String   @id @default(uuid())
  tip       String // CRON_HATA | MAIL_HATA | SENKRON_UYARI | HATA
  kaynak    String // hangi yüzey: cron adı / modül
  mesaj     String   @db.Text
  detayJson Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([tip, createdAt])
}

// demo/satış kaydı — /tanitim sayfasındaki formdan gelen lead'ler. Tenant'a bağlı DEĞİL
// (henüz müşteri değiller). KVKK: yalnız iletişim amacıyla, açık onayla toplanır.
model DemoKaydi {
  id        String   @id @default(uuid())
  ad        String
  eposta    String
  telefon   String?
  buroAd    String? // büro / şirket adı
  mesaj     String?  @db.Text
  kvkkOnay  Boolean  @default(false) // aydınlatma metni onayı (zorunlu; form false göndermez)
  kaynak    String   @default("tanitim") // hangi sayfadan geldi
  durum     String   @default("YENI") // YENI | ARANDI | DEMO_YAPILDI | KAZANILDI | KAYBEDILDI
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([durum, createdAt])
}

// önemli olay — yüksek öncelikli görev/alarm kuyruğu (borca itiraz → arabuluculuk iş akışı).
// TakipOlayi (ham log) ve Asama (hukuki evre) ile karışmaz; bağımsız görev kaydı.
model OnemliOlay {
  id      String          @id @default(uuid())
  dosyaId String
  dosya   RucuDosyasi     @relation(fields: [dosyaId], references: [id], onDelete: Cascade)
  tip     OnemliOlayTip   @default(BORCA_ITIRAZ)
  durum   OnemliOlayDurum @default(ACIK)

  // tetikleyici iz (olaydan ve/veya evraktan tespit)
  kaynakOlayId  String? // TakipOlayi.id
  kaynakBelgeId String? // Belge.id
  tetikTarihi   DateTime // itiraz/tebliğ tarihi (tespit anı default)
  baslik        String? // "Borca itiraz — ödeme emrine"
  sonTarih      DateTime? // ELLE girilir (otomatik kural yok); doluysa renk kodu

  // atama — manuel üstlenme (kilitle)
  sorumluId    String?
  sorumlu      Kullanici? @relation("OnemliOlaySorumlu", fields: [sorumluId], references: [id])
  ustlenildiAt DateTime?

  // tekillik (mükerrerlik önleme) = dosya + tip + tetik GÜNÜ → olay+evrak aynı itirazda tek kayıt
  tekilAnahtar String @unique

  // tamamlama (resmî sistem teyidi)
  basvuruNo     String?
  basvuruTarihi DateTime?
  arabulucu     String?
  tamamlayanId  String?
  tamamlanmaAt  DateTime?
  not           String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dosyaId])
  @@index([durum])
  @@index([sorumluId])
}

// aşama omurgası — dosyaya biriken evreler (İcra → Arabuluculuk → Dava → İnfaz). Aynı dosya, biriken kayıt.
model Asama {
  id             String        @id @default(uuid())
  dosyaId        String
  dosya          RucuDosyasi   @relation(fields: [dosyaId], references: [id], onDelete: Cascade)
  tur            AsamaTur
  durum          AsamaDurum    @default(DEVAM)
  sonuc          String? // anlasildi | anlasilmadi | itiraz | kabul | ret | kesinlesti...
  kimlikNo       String? // icra no / arabuluculuk no / dava esas no
  birim          String? // icra dairesi / arabuluculuk bürosu / mahkeme
  baslangic      DateTime?
  bitis          DateTime?
  tutar          Decimal?      @db.Decimal(14, 2)
  ozet           String?       @db.Text
  detayJson      Json? // türe özel alanlar (arabulucu, bilirkişi, hakim…)
  sira           Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  etkinlikler    Etkinlik[]
  taksitPlanlari TaksitPlani[]
  masraflar      Masraf[]

  @@index([dosyaId])
  @@index([tur])
  @@index([durum])
}

// taksit planı — sulh/anlaşma sonrası ödeme planı (dosyaya + opsiyonel aşamaya bağlı)
model TaksitPlani {
  id            String          @id @default(uuid())
  dosyaId       String
  dosya         RucuDosyasi     @relation(fields: [dosyaId], references: [id], onDelete: Cascade)
  asamaId       String? // sulh hangi evrede yapıldı (arabuluculuk/icra) — bilgi amaçlı
  asama         Asama?          @relation(fields: [asamaId], references: [id], onDelete: SetNull)
  toplamTutar   Decimal         @db.Decimal(14, 2) // anlaşılan net (indirim sonrası)
  indirimTutari Decimal?        @db.Decimal(14, 2) // bilgi amaçlı (uygulanan indirim)
  taksitSayisi  Int
  hatirlatmaGun Int             @default(3) // her taksit vadesinden kaç gün önce hatırlatılsın
  temerrutSarti Boolean         @default(true) // bir taksit kaçarsa kalan muaccel olur (uyarı için)
  durum         TaksitPlanDurum @default(AKTIF)
  not           String?         @db.Text
  taksitler     Taksit[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([dosyaId])
  @@index([durum])
}

// tek taksit — vade + tutar + ödeme/hatırlatma izi
model Taksit {
  id                     String      @id @default(uuid())
  planId                 String
  plan                   TaksitPlani @relation(fields: [planId], references: [id], onDelete: Cascade)
  sira                   Int // 1, 2, 3 … (1/6, 2/6)
  vadeTarihi             DateTime
  tutar                  Decimal     @db.Decimal(14, 2)
  durum                  TaksitDurum @default(BEKLIYOR)
  odenenTutar            Decimal?    @db.Decimal(14, 2) // kısmi ödeme için
  odemeId                String? // ödeme gerçekleşince Odeme kaydına bağ
  odendiTarih            DateTime?
  hatirlatmaGonderildiAt DateTime? // yaklaşan-vade hatırlatması (mükerrer önleme)
  gecikmeBildirildiAt    DateTime? // vade-geçti uyarısı (bir kez)

  @@index([planId])
  @@index([vadeTarihi])
  @@index([durum])
}

// takvim olayı — toplantı / duruşma / süre / hatırlatma (dosyaya + aşamaya bağlı)
model Etkinlik {
  id                     String        @id @default(uuid())
  dosyaId                String
  dosya                  RucuDosyasi   @relation(fields: [dosyaId], references: [id], onDelete: Cascade)
  asamaId                String?
  asama                  Asama?        @relation(fields: [asamaId], references: [id], onDelete: SetNull)
  tur                    EtkinlikTur
  baslik                 String
  baslar                 DateTime
  biter                  DateTime?
  tumGun                 Boolean       @default(false)
  yer                    String?
  online                 Boolean       @default(false)
  durum                  EtkinlikDurum @default(PLANLANDI)
  sonucNot               String?       @db.Text
  sorumluId              String? // atanan avukat (Kullanici.id)
  hatirlatmaDk           Int?
  hatirlatmaGonderildiAt DateTime? // hatırlatma e-postası gönderildiyse zaman damgası (mükerrer gönderimi önler)
  takipGorevleri         TakipGorevi[] // bu etkinlikten doğan takip görevleri (ör. yapılmamış toplantı → "yeni gün ata")
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@index([dosyaId])
  @@index([tur])
  @@index([baslar])
  @@index([durum])
}

// takip görevi — bir etkinlikten (ya da serbest) doğan, bir kişiye atanan iş.
// Senaryo: 24.04 toplantısı YAPILMADI → "arabulucuyla iletişime geç, yeni gün ata" → sorumluya mail.
// Durum makinesi + üstlenme deseni OnemliOlay ile aynı. Tenant kapsamı dosya üzerinden.
model TakipGorevi {
  id                     String          @id @default(uuid())
  dosyaId                String
  dosya                  RucuDosyasi     @relation(fields: [dosyaId], references: [id], onDelete: Cascade)
  etkinlikId             String? // bağlam: hangi etkinlikten doğdu (yapılmamış toplantı vb.)
  etkinlik               Etkinlik?       @relation(fields: [etkinlikId], references: [id], onDelete: SetNull)
  baslik                 String // "Arabulucuyla iletişime geç, yeni gün ata"
  aciklama               String?         @db.Text
  sonTarih               DateTime?
  durum                  TakipGorevDurum @default(ACIK)
  sorumluId              String? // atanan kişi (Kullanici.id) — mail buraya gider
  sorumlu                Kullanici?      @relation("TakipGorevSorumlu", fields: [sorumluId], references: [id])
  atayanId               String? // görevi açan (Kullanici.id)
  mailGonderildiAt       DateTime? // atama maili (anlık) gönderildiyse damga — mükerrer önleme
  hatirlatmaGonderildiAt DateTime? // cron son-tarih hatırlatması gönderildiyse damga — mükerrer önleme
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  @@index([dosyaId])
  @@index([sorumluId, durum])
  @@index([sonTarih])
}

model Not {
  id          String      @id @default(uuid())
  dosyaId     String
  dosya       RucuDosyasi @relation(fields: [dosyaId], references: [id], onDelete: Cascade)
  kullaniciId String?
  kullanici   Kullanici?  @relation(fields: [kullaniciId], references: [id])
  metin       String      @db.Text
  tip         String? // NOT / ARAMA / ISLEM / HATIRLATMA
  createdAt   DateTime    @default(now())

  @@index([dosyaId])
}

// mentor öğrenilen kural — avukat, AI'ın "Önerilen Adımlar"/"Riskler ve Öneriler" çıktısını düzeltir.
// Manuel MVP: kural metni analizEt sistem promptuna OLDUĞU GİBİ enjekte edilir (AI damıtma yok) →
// sonraki çıkarımlar bu düzeltmelere uyar. Tenant kapsamlı; olayTuru doluysa yalnız o türde uygulanır.
model MentorKural {
  id          String         @id @default(uuid())
  musteriId   String
  musteri     Musteri        @relation(fields: [musteriId], references: [id], onDelete: Cascade)
  kaynak      MentorKaynak   @default(ADIM)
  tur         MentorKuralTur @default(KALDIR)
  hedef       String?        @db.Text // geri bildirim verilen orijinal öneri metni (bağlam)
  yorum       String         @db.Text // kullanıcının düzeltmesi / yönergesi (prompta giren asıl kural)
  olayTuru    String? // null = tüm dosyalar; dolu = yalnız bu olay türünde uygula
  aktif       Boolean        @default(true)
  dosyaId     String? // iz: hangi dosyada verildi (FK yok — dosya silinse de kural yaşar)
  kullaniciId String?
  kullanici   Kullanici?     @relation("MentorKuralYazan", fields: [kullaniciId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([musteriId, aktif])
}

// audit — "kim ne zaman ne yaptı" (Dosya Detay / Yelda senaryosu)
model Aktivite {
  id          String       @id @default(uuid())
  dosyaId     String?
  dosya       RucuDosyasi? @relation(fields: [dosyaId], references: [id], onDelete: SetNull)
  kullaniciId String?
  kullanici   Kullanici?   @relation(fields: [kullaniciId], references: [id])
  eylem       String // "takip-aç bloğu üretildi", "durum → TAKIBE_HAZIR" ...
  detayJson   Json?
  createdAt   DateTime     @default(now())

  @@index([dosyaId])
}
